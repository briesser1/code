## Recommended Implementation Path

### Phase 1: Build the Aggregate Knowledge Graph

**Step 1.1: Aggregate Relationships**
```sql
-- Create master edge list with frequency weighting
CREATE TABLE knowledge_graph_edges AS
SELECT
    source_label,
    relationship_type,
    target_label,
    COUNT(*) AS frequency,
    AVG(CASE WHEN confidence = 'high' THEN 1.0
             WHEN confidence = 'medium' THEN 0.6
             ELSE 0.3 END) AS avg_confidence_weight,
    -- Outcome correlation
    SUM(CASE WHEN item_rating = 'area_needing_improvement' THEN 1 ELSE 0 END) AS poor_outcome_count,
    SUM(CASE WHEN item_rating = 'strength' THEN 1 ELSE 0 END) AS good_outcome_count,
    -- Associated themes
    ARRAY_AGG(DISTINCT related_theme_id) AS theme_associations
FROM cfsr_relationships r
JOIN cfsr_case_summary c USING (case_id, item_number, round)
GROUP BY source_label, relationship_type, target_label;
```

**Step 1.2: Create Node Metadata**
```sql
-- Calculate node statistics
CREATE TABLE knowledge_graph_nodes AS
WITH node_stats AS (
    SELECT source_label AS node_label,
           COUNT(*) AS out_degree,
           0 AS in_degree
    FROM cfsr_relationships
    GROUP BY source_label
    UNION ALL
    SELECT target_label AS node_label,
           0 AS out_degree,
           COUNT(*) AS in_degree
    FROM cfsr_relationships
    GROUP BY target_label
)
SELECT
    node_label,
    SUM(out_degree) AS total_out_degree,
    SUM(in_degree) AS total_in_degree,
    SUM(out_degree) + SUM(in_degree) AS total_degree,
    ROUND(SUM(out_degree)::NUMERIC / NULLIF(SUM(out_degree) + SUM(in_degree), 0), 3) AS causal_centrality
FROM node_stats
GROUP BY node_label;
```

**Step 1.3: Add Outcome Correlation**
```sql
-- Add outcome correlation metadata to nodes
ALTER TABLE knowledge_graph_nodes ADD COLUMN poor_outcome_correlation NUMERIC;
ALTER TABLE knowledge_graph_nodes ADD COLUMN good_outcome_correlation NUMERIC;

UPDATE knowledge_graph_nodes n
SET
    poor_outcome_correlation = (
        SELECT COUNT(DISTINCT r.case_id)::NUMERIC / NULLIF(COUNT(DISTINCT c.case_id), 0)
        FROM cfsr_relationships r
        JOIN cfsr_case_summary c USING (case_id, item_number, round)
        WHERE (r.source_label = n.node_label OR r.target_label = n.node_label)
          AND c.item_rating = 'area_needing_improvement'
    ),
    good_outcome_correlation = (
        SELECT COUNT(DISTINCT r.case_id)::NUMERIC / NULLIF(COUNT(DISTINCT c.case_id), 0)
        FROM cfsr_relationships r
        JOIN cfsr_case_summary c USING (case_id, item_number, round)
        WHERE (r.source_label = n.node_label OR r.target_label = n.node_label)
          AND c.item_rating = 'strength'
    );
```

