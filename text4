-- ==============================================================================
-- CFSR Extraction Database Schema
-- ==============================================================================
--
-- Relational database schema for storing LLM-extracted CFSR item data.
-- Supports all 18 OSRI items across Round 3 and Round 4.
--
-- Tables:
--   1. cfsr_case_summary     - Case-level extraction metadata and summary
--   2. cfsr_themes           - Theme extraction results
--   3. cfsr_concerns_strengths - Primary concerns and strengths
--   4. cfsr_semantic_objects - Semantic objects from relationship mapping
--   5. cfsr_relationships    - Relationship edge list (causal graph)
--   6. cfsr_relationship_themes - Bridge table linking relationships to themes
--   7. cfsr_item_reference   - Reference table for CFSR items
--
-- Designed for:
--   - PostgreSQL (primary)
--   - Snowflake (with minor syntax adjustments)
--   - SQLite (for local testing)
--
-- ==============================================================================


-- ==============================================================================
-- REFERENCE TABLE: CFSR Items
-- ==============================================================================

CREATE TABLE IF NOT EXISTS cfsr_item_reference (
    item_number         INTEGER PRIMARY KEY,
    item_name           VARCHAR(200) NOT NULL,
    outcome_category    VARCHAR(100) NOT NULL,
    outcome_number      INTEGER NOT NULL,
    item_question       TEXT,
    round_3_applies     BOOLEAN DEFAULT TRUE,
    round_4_applies     BOOLEAN DEFAULT TRUE
);

