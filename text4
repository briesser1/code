-- ==============================================================================
-- TABLE 1: Case Summary (one row per case/item/round extraction)
-- ==============================================================================

CREATE TABLE IF NOT EXISTS cfsr_case_summary (
    -- Primary key
    extraction_id           SERIAL PRIMARY KEY,

    -- Case identification
    case_id                 VARCHAR(100),
    item_number             INTEGER NOT NULL,
    round                   INTEGER NOT NULL CHECK (round IN (3, 4)),
    state                   VARCHAR(10),
    county                  VARCHAR(100),
    review_period           VARCHAR(50),

    -- Extraction metadata
    extraction_timestamp    TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    -- Standard extraction fields
    item_name               VARCHAR(200),
    case_summary_text       TEXT,
    item_rating             VARCHAR(50) CHECK (item_rating IN ('strength', 'area_needing_improvement', 'not_applicable')),

    -- Item-specific fields (nullable, varies by item)
    permanency_goal         VARCHAR(50),
    concurrent_goal         VARCHAR(50),
    permanency_progress     VARCHAR(50),
    entry_type              VARCHAR(50),
    placement_count         INTEGER,
    current_placement_type  VARCHAR(50),
    reports_reviewed        INTEGER,
    reports_timely          INTEGER,
    total_siblings_in_care  INTEGER,
    siblings_placed_together INTEGER,
    siblings_placed_separately INTEGER,
    separation_justified    VARCHAR(20),
    diligent_search_completed VARCHAR(20),
    relatives_identified    INTEGER,
    current_placement_with_relative VARCHAR(10),
    child_school_age        VARCHAR(10),
    icwa_applicable         VARCHAR(10),

    -- Nested assessment objects stored as JSON strings
    visitation_assessment   TEXT,
    involvement_assessment  TEXT,
    visit_assessment        TEXT,
    assessment_by_party     TEXT,
    connections_assessed    TEXT,
    health_status           TEXT,
    mental_health_status    TEXT,
    educational_status      TEXT,
    relationship_support_assessment TEXT,

    -- Foreign key constraint
    FOREIGN KEY (item_number) REFERENCES cfsr_item_reference(item_number),

    -- Unique constraint to prevent duplicate extractions
    UNIQUE (case_id, item_number, round)
);

-- Indexes for common queries
CREATE INDEX idx_case_summary_case ON cfsr_case_summary(case_id);
CREATE INDEX idx_case_summary_item ON cfsr_case_summary(item_number);
CREATE INDEX idx_case_summary_round ON cfsr_case_summary(round);
CREATE INDEX idx_case_summary_state ON cfsr_case_summary(state);
CREATE INDEX idx_case_summary_rating ON cfsr_case_summary(item_rating);


-- ==============================================================================
-- TABLE 2: Themes (multiple rows per extraction)
-- ==============================================================================

CREATE TABLE IF NOT EXISTS cfsr_themes (
    -- Primary key
    theme_row_id            SERIAL PRIMARY KEY,

    -- Case identification (matches case_summary)
    case_id                 VARCHAR(100),
    item_number             INTEGER NOT NULL,
    round                   INTEGER NOT NULL CHECK (round IN (3, 4)),
    state                   VARCHAR(10),
    county                  VARCHAR(100),
    review_period           VARCHAR(50),

    -- Theme data
    theme_id                VARCHAR(20),
    theme                   VARCHAR(100) NOT NULL,
    finding                 VARCHAR(20) CHECK (finding IN ('strength', 'concern', 'neutral')),
    excerpt                 TEXT,
    actor                   VARCHAR(50),
    timeframe               VARCHAR(50),

    -- Foreign key
    FOREIGN KEY (item_number) REFERENCES cfsr_item_reference(item_number)
);

-- Indexes
CREATE INDEX idx_themes_case ON cfsr_themes(case_id);
CREATE INDEX idx_themes_item ON cfsr_themes(item_number);
CREATE INDEX idx_themes_theme ON cfsr_themes(theme);
CREATE INDEX idx_themes_finding ON cfsr_themes(finding);
CREATE INDEX idx_themes_actor ON cfsr_themes(actor);


-- ==============================================================================
-- TABLE 3: Concerns and Strengths (multiple rows per extraction)
-- ==============================================================================

CREATE TABLE IF NOT EXISTS cfsr_concerns_strengths (
    -- Primary key
    cs_row_id               SERIAL PRIMARY KEY,

    -- Case identification
    case_id                 VARCHAR(100),
    item_number             INTEGER NOT NULL,
    round                   INTEGER NOT NULL CHECK (round IN (3, 4)),
    state                   VARCHAR(10),
    county                  VARCHAR(100),
    review_period           VARCHAR(50),

    -- Data
    type                    VARCHAR(50) NOT NULL,
    value                   TEXT NOT NULL,

    -- Foreign key
    FOREIGN KEY (item_number) REFERENCES cfsr_item_reference(item_number)
);

-- Indexes
CREATE INDEX idx_cs_case ON cfsr_concerns_strengths(case_id);
CREATE INDEX idx_cs_item ON cfsr_concerns_strengths(item_number);
CREATE INDEX idx_cs_type ON cfsr_concerns_strengths(type);


-- ==============================================================================
-- TABLE 4: Semantic Objects (nodes in the relationship graph)
-- ==============================================================================

CREATE TABLE IF NOT EXISTS cfsr_semantic_objects (
    -- Primary key
    object_row_id           SERIAL PRIMARY KEY,

    -- Case identification
    case_id                 VARCHAR(100),
    item_number             INTEGER NOT NULL,
    round                   INTEGER NOT NULL CHECK (round IN (3, 4)),
    state                   VARCHAR(10),
    county                  VARCHAR(100),
    review_period           VARCHAR(50),

    -- Object data
    object_id               VARCHAR(20),
    label                   VARCHAR(500) NOT NULL,
    object_type             VARCHAR(50),
    sentiment               VARCHAR(20) CHECK (sentiment IN ('positive', 'negative', 'neutral')),

    -- Foreign key
    FOREIGN KEY (item_number) REFERENCES cfsr_item_reference(item_number)
);

-- Indexes
CREATE INDEX idx_so_case ON cfsr_semantic_objects(case_id);
CREATE INDEX idx_so_item ON cfsr_semantic_objects(item_number);
CREATE INDEX idx_so_type ON cfsr_semantic_objects(object_type);
CREATE INDEX idx_so_sentiment ON cfsr_semantic_objects(sentiment);
CREATE INDEX idx_so_label ON cfsr_semantic_objects(label);


-- ==============================================================================
-- TABLE 5: Relationships (edges in the causal graph)
-- ==============================================================================

CREATE TABLE IF NOT EXISTS cfsr_relationships (
    -- Primary key
    relationship_row_id     SERIAL PRIMARY KEY,

    -- Case identification
    case_id                 VARCHAR(100),
    item_number             INTEGER NOT NULL,
    round                   INTEGER NOT NULL CHECK (round IN (3, 4)),
    state                   VARCHAR(10),
    county                  VARCHAR(100),
    review_period           VARCHAR(50),

    -- Relationship data
    source_object_id        VARCHAR(20),
    source_label            VARCHAR(500),
    relationship_type       VARCHAR(50) NOT NULL,
    target_object_id        VARCHAR(20),
    target_label            VARCHAR(500),
    confidence              VARCHAR(20) CHECK (confidence IN ('high', 'medium', 'low')),
    directionality          VARCHAR(20) CHECK (directionality IN ('explicit', 'inferred')),
    related_themes_flat     VARCHAR(200),

    -- Foreign key
    FOREIGN KEY (item_number) REFERENCES cfsr_item_reference(item_number)
);

-- Indexes
CREATE INDEX idx_rel_case ON cfsr_relationships(case_id);
CREATE INDEX idx_rel_item ON cfsr_relationships(item_number);
CREATE INDEX idx_rel_type ON cfsr_relationships(relationship_type);
CREATE INDEX idx_rel_source ON cfsr_relationships(source_label);
CREATE INDEX idx_rel_target ON cfsr_relationships(target_label);
CREATE INDEX idx_rel_confidence ON cfsr_relationships(confidence);


-- ==============================================================================
-- TABLE 6: Relationship-Theme Bridge (links relationships to themes)
-- ==============================================================================

CREATE TABLE IF NOT EXISTS cfsr_relationship_themes (
    -- Primary key
    rt_row_id               SERIAL PRIMARY KEY,

    -- Case identification
    case_id                 VARCHAR(100),
    item_number             INTEGER NOT NULL,
    round                   INTEGER NOT NULL CHECK (round IN (3, 4)),
    state                   VARCHAR(10),
    county                  VARCHAR(100),
    review_period           VARCHAR(50),

    -- Bridge data
    source_label            VARCHAR(500),
    relationship_type       VARCHAR(50),
    target_label            VARCHAR(500),
    related_theme_id        VARCHAR(20),

    -- Foreign key
    FOREIGN KEY (item_number) REFERENCES cfsr_item_reference(item_number)
);

-- Indexes
CREATE INDEX idx_rt_case ON cfsr_relationship_themes(case_id);
CREATE INDEX idx_rt_theme ON cfsr_relationship_themes(related_theme_id);


-- ==============================================================================
-- ANALYTICAL VIEWS
-- ==============================================================================

-- View: Theme distribution across items and rounds
CREATE OR REPLACE VIEW vw_theme_distribution AS
SELECT
    item_number,
    round,
    theme,
    finding,
    COUNT(*) AS occurrence_count,
    COUNT(DISTINCT case_id) AS case_count
FROM cfsr_themes
GROUP BY item_number, round, theme, finding
ORDER BY item_number, round, occurrence_count DESC;


-- View: Item ratings summary
CREATE OR REPLACE VIEW vw_item_ratings AS
SELECT
    item_number,
    round,
    state,
    item_rating,
    COUNT(*) AS case_count,
    ROUND(100.0 * COUNT(*) / SUM(COUNT(*)) OVER (PARTITION BY item_number, round, state), 1) AS pct
FROM cfsr_case_summary
WHERE item_rating IS NOT NULL
GROUP BY item_number, round, state, item_rating
ORDER BY item_number, round, state;


-- View: Most common relationship patterns
CREATE OR REPLACE VIEW vw_common_relationships AS
SELECT
    item_number,
    round,
    source_label,
    relationship_type,
    target_label,
    COUNT(*) AS occurrence_count,
    COUNT(DISTINCT case_id) AS case_count,
    SUM(CASE WHEN confidence = 'high' THEN 1 ELSE 0 END) AS high_confidence_count
FROM cfsr_relationships
GROUP BY item_number, round, source_label, relationship_type, target_label
HAVING COUNT(DISTINCT case_id) >= 2
ORDER BY case_count DESC;


-- View: Semantic objects as root causes (high out-degree)
CREATE OR REPLACE VIEW vw_root_causes AS
SELECT
    r.item_number,
    r.round,
    r.source_label,
    so.object_type,
    so.sentiment,
    COUNT(DISTINCT r.case_id) AS cases_as_cause,
    COUNT(*) AS total_outgoing_edges
FROM cfsr_relationships r
LEFT JOIN cfsr_semantic_objects so
    ON r.case_id = so.case_id
    AND r.item_number = so.item_number
    AND r.source_object_id = so.object_id
WHERE r.relationship_type IN ('causes', 'leads_to', 'contributes_to', 'triggers')
GROUP BY r.item_number, r.round, r.source_label, so.object_type, so.sentiment
ORDER BY cases_as_cause DESC, total_outgoing_edges DESC;


-- View: Actors most frequently associated with concerns
CREATE OR REPLACE VIEW vw_actor_concerns AS
SELECT
    item_number,
    round,
    actor,
    COUNT(*) AS concern_count,
    COUNT(DISTINCT case_id) AS case_count
FROM cfsr_themes
WHERE finding = 'concern'
GROUP BY item_number, round, actor
ORDER BY concern_count DESC;


